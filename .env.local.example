# ─── SUPABASE ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── ANTHROPIC CLAUDE API ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── RESEND (emails transaccionales) ─────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@tudominio.com

# ─── CULQI (pasarela de pagos Perú) ──────────────────────────
NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_live_...
CULQI_PRIVATE_KEY=sk_live_...
CULQI_WEBHOOK_SECRET=...

# Modo mock: omite validación real de Culqi (solo desarrollo/testing)
# Poner ambas en "true" para activar. Quitar o poner "false" en producción.
NEXT_PUBLIC_CULQI_MOCK=true
CULQI_MOCK=true

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KODA

# ─── CRON (Vercel Cron Jobs) ─────────────────────────────────
# Genera con: openssl rand -hex 32
CRON_SECRET=...
